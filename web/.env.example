.env
SECRET_KEY=your-super-secret-key-change-this-in-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,api.example.com
DB_NAME=x2dhf_db
DB_ENGINE=postgresql
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db
DB_PORT=5432
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://example.com
STRIPE_PUBLIC_KEY=pk_test_xxxxx
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
X2DHF_DIRECTORY=..
X2DHF_BINARY_PATH=../bin/xhf
QE_BINARY_PATH=/usr/local/bin/pw.x
LIBXC_LIBRARY_PATH=/usr/local/lib
PSEUDO_DIR=/opt/pseudopotentials
COMPUTATION_WORKDIR=/tmp/x2dhf-jobs
AUTO_START_COMPUTATIONS=True
MAX_COMPUTATION_TIME=3600
MAX_GRID_SIZE=1000
STORAGE_QUOTA_GB=10
REACT_APP_API_URL=http://localhost:8000/api
