{
  "python.defaultInterpreterPath": "${workspaceFolder}\\web\\backend\\.venv\\Scripts\\python.exe",
  "python.terminal.activateEnvironment": true,
  "python.envFile": "${workspaceFolder}\\web\\backend\\.env",
  "python.analysis.extraPaths": [
    "${workspaceFolder}\\web\\backend\\x2dhf_project",
    "${workspaceFolder}\\web\\backend"
  ],
  "python.analysis.diagnosticMode": "openFilesOnly",
  "python.analysis.exclude": [
    "**/.venv",
    "**/node_modules",
    "**/build",
    "**/staticfiles",
    "**/job_workdir",
    "../x2dhf-saas/**",
    "C:/Users/Administrator/Downloads/x2dhf-saas/**",
    "**/__pycache__",
    "**/.pytest_cache"
  ],
  "python.analysis.useLibraryCodeForTypes": true,
  "javascript.validate.enable": false,
  "typescript.validate.enable": false,
  "python.testing.pytestEnabled": true,
  "python.testing.cwd": "${workspaceFolder}\\web\\backend",
  "python.testing.pytestArgs": [
    "."
  ],
  "python.testing.unittestEnabled": false,
  "files.exclude": {
    "**/__pycache__": true,
    "**/.pytest_cache": true,
    "**/.venv": true,
    "../x2dhf-saas": true,
    "web/frontend/node_modules": true,
    "web/frontend/build": true,
    "web/backend/staticfiles": true,
    "web/backend/job_workdir": true
  },
  "search.exclude": {
    "**/.venv": true,
    "**/node_modules": true,
    "**/build": true,
    "**/staticfiles": true,
    "**/job_workdir": true,
    "../x2dhf-saas": true
  },
  "files.watcherExclude": {
    "**/.venv/**": true,
    "**/node_modules/**": true,
    "**/build/**": true,
    "**/staticfiles/**": true,
    "**/job_workdir/**": true
  }
}
